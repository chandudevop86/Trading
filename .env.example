# Vinayak top-level example environment file
# Prefer app/vinayak/.env for app-local development.

APP_NAME=Vinayak Trading Platform
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

VINAYAK_DATABASE_URL=sqlite:///app/vinayak/data/vinayak.db
VINAYAK_ADMIN_USERNAME=admin
VINAYAK_ADMIN_PASSWORD=vinayak-admin-2026
VINAYAK_ADMIN_SECRET=vinayak-dev-secret-2026-04-15-a7c91f3d5e2b4c18
VINAYAK_SECURE_COOKIES=false
VINAYAK_AUTO_LOGIN=false
VINAYAK_SYNC_ADMIN_FROM_ENV=false
VINAYAK_ENABLE_SYNC_LIVE_ANALYSIS=true
VINAYAK_ENABLE_LIVE_TRADING=false
VINAYAK_ENABLE_PAPER_TRADING=true
VINAYAK_LOG_LEVEL=INFO
VINAYAK_JSON_LOGS=true
VINAYAK_REQUEST_ID_HEADER=X-Request-ID
VINAYAK_HEALTH_READY_CACHE_TTL_SECONDS=10

REDIS_URL=redis://localhost:6379/0
REDIS_DEFAULT_TTL_SECONDS=900
MESSAGE_BUS_ENABLED=false
MESSAGE_BUS_BACKEND=rabbitmq
MESSAGE_BUS_URL=amqp://guest:guest@localhost:5672/
MESSAGE_BUS_TOPIC_PREFIX=vinayak

DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=
DHAN_BASE_URL=https://api-hq.dhan.co
DHAN_TIMEOUT=30
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
