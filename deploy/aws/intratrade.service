[Unit]
Description=Intratrade Streamlit App
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/trading
Environment="PATH=/opt/trading/.venv/bin"
ExecStart=/opt/trading/.venv/bin/streamlit run src/Trading.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
