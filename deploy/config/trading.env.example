APP_ENV=production
AWS_REGION=ap-south-1
AWS_S3_ENABLED=true
AWS_S3_BUCKET=your-trading-bucket
AWS_S3_PREFIX=trading/prod
TRADING_DATA_DIR=data
TRADING_LOG_DIR=logs
TRADING_STRATEGY=Breakout
TRADING_SYMBOL=^NSEI
TRADING_INTERVAL=5m
TRADING_CAPITAL=100000
TRADING_RISK_PCT=1.0
TRADING_RR_RATIO=2.0
TRADING_MODE=Balanced
TRADING_BROKER_MODE=PAPER
TRADING_POLL_INTERVAL_SECONDS=300
TRADING_RUN_BACKTEST=true
LIVE_TRADING_ENABLED=false
MAX_TRADES_PER_DAY=3
MAX_DAILY_LOSS=0
MAX_ORDER_QUANTITY=0
MAX_ORDER_VALUE=0
LIVE_SYMBOL_ALLOWLIST=NIFTY,BANKNIFTY
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=
DHAN_SECURITY_MAP=data/dhan_security_map.csv
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

