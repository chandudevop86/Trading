1 0 0 1 50 730 Tm (# image: <dockerhub-user>/intratrade:latest) Tj
1 0 0 1 50 716 Tm (kubectl apply -f deploy/k8s/deployment.yaml) Tj
1 0 0 1 50 702 Tm (```) Tj
1 0 0 1 50 688 Tm () Tj
