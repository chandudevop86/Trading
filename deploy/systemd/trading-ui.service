[Unit]
Description=Trading Streamlit UI
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/trading
EnvironmentFile=/etc/trading/trading.env
ExecStart=/opt/trading/.venv/bin/streamlit run /opt/trading/src/Trading.py --server.port 8501 --server.address 0.0.0.0
Restart=always
RestartSec=5
StandardOutput=append:/var/log/trading/ui.log
StandardError=append:/var/log/trading/ui-error.log

[Install]
WantedBy=multi-user.target
