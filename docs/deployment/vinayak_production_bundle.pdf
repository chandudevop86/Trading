(# Vinayak Production Bundle) Tj
T* () Tj
T* (## Environment File) Tj
T* (Path: `infra/production/env/vinayak.production.env.example`) Tj
T* () Tj
T* (```env) Tj
T* (APP_ENV=prod) Tj
T* (VINAYAK_DATABASE_URL=postgresql+psycopg://vinayak:REPLACE_DB_PASSWORD@postgres-host:5432/vinaya) Tj
T* (k) Tj
T* (REDIS_URL=redis://redis-host:6379/0) Tj
T* (REDIS_DEFAULT_TTL_SECONDS=900) Tj
T* (VINAYAK_ADMIN_USERNAME=admin) Tj
T* (VINAYAK_ADMIN_PASSWORD=REPLACE_STRONG_ADMIN_PASSWORD) Tj
T* (VINAYAK_ADMIN_SECRET=REPLACE_LONG_RANDOM_SECRET) Tj
T* (VINAYAK_API_BASE_URL=http://127.0.0.1/api) Tj
T* (MESSAGE_BUS_ENABLED=false) Tj
T* (```) Tj
T* () Tj
T* (## API systemd Unit) Tj
T* (Path: `infra/production/systemd/vinayak-api.service`) Tj
T* () Tj
T* (```ini) Tj
T* ([Unit]) Tj
T* (Description=Vinayak FastAPI service) Tj
T* (After=network.target) Tj
T* () Tj
T* ([Service]) Tj
T* (Type=simple) Tj
T* (User=root) Tj
T* (WorkingDirectory=/root/Trading) Tj
T* (EnvironmentFile=/root/Trading/infra/production/env/vinayak.production.env) Tj
T* (ExecStart=/root/Trading/venv/bin/python -m uvicorn app.vinayak.api.main:app --host 0.0.0.0) Tj
T* (--port 8000) Tj
T* (Restart=always) Tj
T* (RestartSec=5) Tj
T* (TimeoutStopSec=20) Tj
T* () Tj
T* ([Install]) Tj
T* (WantedBy=multi-user.target) Tj
T* (```) Tj
T* () Tj
T* (## UI systemd Unit) Tj
T* (Path: `infra/production/systemd/vinayak-ui.service`) Tj
T* () Tj
T* (```ini) Tj
T* ([Unit]) Tj
T* (Description=Vinayak Streamlit UI) Tj
T* (After=network.target vinayak-api.service) Tj
ET
endstream
endobj
