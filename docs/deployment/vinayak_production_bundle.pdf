(Requires=vinayak-api.service) Tj
T* () Tj
T* ([Service]) Tj
T* (Type=simple) Tj
T* (User=root) Tj
T* (WorkingDirectory=/root/Trading) Tj
T* (EnvironmentFile=/root/Trading/infra/production/env/vinayak.production.env) Tj
T* (Environment=VINAYAK_API_BASE_URL=http://127.0.0.1/api) Tj
T* (ExecStart=/root/Trading/venv/bin/python -m streamlit run app/vinayak/ui/app.py) Tj
T* (--server.address 0.0.0.0 --server.port 8501) Tj
T* (Restart=always) Tj
T* (RestartSec=5) Tj
T* (TimeoutStopSec=20) Tj
T* () Tj
T* ([Install]) Tj
T* (WantedBy=multi-user.target) Tj
T* (```) Tj
T* () Tj
T* (## Nginx Reverse Proxy) Tj
T* (Path: `infra/production/nginx/vinayak.conf`) Tj
T* () Tj
T* (```nginx) Tj
T* (server {) Tj
T* (    listen 80;) Tj
T* (    server_name _;) Tj
T* (    client_max_body_size 20m;) Tj
T* () Tj
T* (    proxy_http_version 1.1;) Tj
T* (    proxy_set_header Host $host;) Tj
T* (    proxy_set_header X-Real-IP $remote_addr;) Tj
T* (    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;) Tj
T* (    proxy_set_header X-Forwarded-Proto $scheme;) Tj
T* () Tj
T* (    location /api/ {) Tj
T* (        proxy_pass http://127.0.0.1:8000/;) Tj
T* (        proxy_read_timeout 120s;) Tj
T* (    }) Tj
T* () Tj
T* (    location /health {) Tj
T* (        proxy_pass http://127.0.0.1:8000/health;) Tj
T* (        proxy_read_timeout 30s;) Tj
T* (    }) Tj
T* () Tj
T* (    location /health/ready {) Tj
T* (        proxy_pass http://127.0.0.1:8000/health/ready;) Tj
T* (        proxy_read_timeout 30s;) Tj
T* (    }) Tj
T* () Tj
ET
endstream
