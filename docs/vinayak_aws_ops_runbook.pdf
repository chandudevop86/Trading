1 0 0 1 50 632 Tm (LIVE_TRADING_ENABLED=false) Tj
1 0 0 1 50 618 Tm (TRADING_BROKER_MODE=PAPER) Tj
1 0 0 1 50 604 Tm () Tj
1 0 0 1 50 590 Tm (Lock the file:) Tj
1 0 0 1 50 576 Tm (sudo chmod 600 /etc/vinayak/vinayak.env) Tj
1 0 0 1 50 562 Tm () Tj
1 0 0 1 50 548 Tm (NGINX REVERSE PROXY) Tj
1 0 0 1 50 534 Tm () Tj
1 0 0 1 50 520 Tm (Example /etc/nginx/sites-available/vinayak:) Tj
1 0 0 1 50 506 Tm () Tj
1 0 0 1 50 492 Tm (server {) Tj
1 0 0 1 50 478 Tm (    listen 80;) Tj
1 0 0 1 50 464 Tm (    server_name vinayak.yourdomain.com;) Tj
1 0 0 1 50 450 Tm () Tj
1 0 0 1 50 436 Tm (    location / {) Tj
1 0 0 1 50 422 Tm (        proxy_pass http://127.0.0.1:8000;) Tj
1 0 0 1 50 408 Tm (        proxy_set_header Host $host;) Tj
1 0 0 1 50 394 Tm (        proxy_set_header X-Real-IP $remote_addr;) Tj
1 0 0 1 50 380 Tm (        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;) Tj
1 0 0 1 50 366 Tm (        proxy_set_header X-Forwarded-Proto $scheme;) Tj
1 0 0 1 50 352 Tm (    }) Tj
1 0 0 1 50 338 Tm (}) Tj
1 0 0 1 50 324 Tm () Tj
1 0 0 1 50 310 Tm (Enable it:) Tj
1 0 0 1 50 296 Tm (sudo ln -s /etc/nginx/sites-available/vinayak /etc/nginx/sites-enabled/vinayak) Tj
1 0 0 1 50 282 Tm (sudo nginx -t) Tj
1 0 0 1 50 268 Tm (sudo systemctl restart nginx) Tj
