APP_NAME=Vinayak Trading Platform
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
VINAYAK_DATABASE_URL=postgresql+psycopg2://vinayak:${POSTGRES_PASSWORD}@prod-postgres:5432/vinayak
REDIS_URL=redis://prod-redis:6379/0
MESSAGE_BUS_ENABLED=true
MESSAGE_BUS_BACKEND=rabbitmq
MESSAGE_BUS_URL=amqp://vinayak:${RABBITMQ_PASSWORD}@prod-rabbitmq:5672/
MESSAGE_BUS_TOPIC_PREFIX=vinayak
MONGODB_URL=
MONGODB_DATABASE=vinayak
MONGODB_PRODUCT_COLLECTION=product_catalog
VINAYAK_ADMIN_USERNAME=admin
VINAYAK_ADMIN_PASSWORD=change-me-in-production
VINAYAK_ADMIN_SECRET=change-me-in-production
REPORTS_DIR=/app/app/vinayak/data/reports
REPORTS_S3_BUCKET=vinayak-prod-reports
REPORTS_S3_PREFIX=vinayak/reports
AWS_REGION=ap-south-1

