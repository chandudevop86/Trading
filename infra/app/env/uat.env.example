APP_NAME=Vinayak Trading Platform
APP_ENV=uat
APP_HOST=0.0.0.0
APP_PORT=8000
VINAYAK_DATABASE_URL=postgresql+psycopg2://vinayak:vinayak@uat-postgres:5432/vinayak
REDIS_URL=redis://uat-redis:6379/0
MESSAGE_BUS_ENABLED=true
MESSAGE_BUS_BACKEND=rabbitmq
MESSAGE_BUS_URL=amqp://guest:guest@uat-rabbitmq:5672/
MESSAGE_BUS_TOPIC_PREFIX=vinayak.uat
MONGODB_URL=
MONGODB_DATABASE=vinayak_uat
MONGODB_PRODUCT_COLLECTION=product_catalog
VINAYAK_ADMIN_USERNAME=admin
VINAYAK_ADMIN_PASSWORD=change-me-in-uat
VINAYAK_ADMIN_SECRET=change-me-in-uat
REPORTS_DIR=vinayak/data/reports
REPORTS_S3_BUCKET=
AWS_REGION=ap-south-1
