{
  "agent": {
    "metrics_collection_interval": 60,
    "run_as_user": "cwagent"
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/opt/trading/logs/app.log",
            "log_group_name": "/trading/app",
            "log_stream_name": "{instance_id}"
          },
          {
            "file_path": "/opt/trading/logs/execution.log",
            "log_group_name": "/trading/execution",
            "log_stream_name": "{instance_id}"
          },
          {
            "file_path": "/opt/trading/logs/broker.log",
            "log_group_name": "/trading/broker",
            "log_stream_name": "{instance_id}"
          },
          {
            "file_path": "/opt/trading/logs/errors.log",
            "log_group_name": "/trading/errors",
            "log_stream_name": "{instance_id}"
          },
          {
            "file_path": "/var/log/trading/ui-error.log",
            "log_group_name": "/trading/ui-error",
            "log_stream_name": "{instance_id}"
          },
          {
            "file_path": "/var/log/trading/daemon-error.log",
            "log_group_name": "/trading/daemon-error",
            "log_stream_name": "{instance_id}"
          }
        ]
      }
    }
  },
  "metrics": {
    "append_dimensions": {
      "InstanceId": "${aws:InstanceId}",
      "AutoScalingGroupName": "${aws:AutoScalingGroupName}"
    },
    "metrics_collected": {
      "cpu": {
        "measurement": ["cpu_usage_idle", "cpu_usage_user", "cpu_usage_system"],
        "metrics_collection_interval": 60,
        "totalcpu": true
      },
      "mem": {
        "measurement": ["mem_used_percent"],
        "metrics_collection_interval": 60
      },
      "disk": {
        "measurement": ["used_percent"],
        "metrics_collection_interval": 60,
        "resources": ["/"]
      }
    }
  }
}
