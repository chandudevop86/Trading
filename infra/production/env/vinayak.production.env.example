APP_ENV=prod

VINAYAK_DATABASE_URL=postgresql+psycopg://vinayak:REPLACE_DB_PASSWORD@postgres-host:5432/vinayak
REDIS_URL=redis://redis-host:6379/0
REDIS_DEFAULT_TTL_SECONDS=900

VINAYAK_ADMIN_USERNAME=admin
VINAYAK_ADMIN_PASSWORD=REPLACE_STRONG_ADMIN_PASSWORD
VINAYAK_ADMIN_SECRET=REPLACE_LONG_RANDOM_SECRET
VINAYAK_SECURE_COOKIES=true
VINAYAK_AUTO_LOGIN=false
VINAYAK_SYNC_ADMIN_FROM_ENV=false
VINAYAK_ENABLE_SYNC_LIVE_ANALYSIS=false
VINAYAK_ENABLE_LIVE_TRADING=false
VINAYAK_ENABLE_PAPER_TRADING=true
VINAYAK_LOG_LEVEL=INFO
VINAYAK_JSON_LOGS=true
VINAYAK_REQUEST_ID_HEADER=X-Request-ID
VINAYAK_HEALTH_READY_CACHE_TTL_SECONDS=10

MESSAGE_BUS_ENABLED=false
MESSAGE_BUS_BACKEND=rabbitmq
MESSAGE_BUS_URL=amqp://guest:guest@rabbitmq-host:5672/
MESSAGE_BUS_TOPIC_PREFIX=vinayak
