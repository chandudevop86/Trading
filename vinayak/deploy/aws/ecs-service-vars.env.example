AWS_REGION=ap-south-1
REPORTS_S3_BUCKET=vinayak-reports-prod
REDIS_URL=redis://vinayak-redis.<cache-id>.use1.cache.amazonaws.com:6379/0

# Store these in Secrets Manager in production instead of plaintext env files.
VINAYAK_DATABASE_URL=postgresql+psycopg2://vinayak:<password>@<rds-endpoint>:5432/vinayak
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
